# ============ MultiAceros B&M — variables de entorno ============
# Copia este archivo a .env.local y completa los valores.
# NUNCA subas .env.local al repositorio (ya está en .gitignore).

# URL pública del sitio (para metadatos y SEO)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (se completa al crear el proyecto) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave de servicio: SOLO servidor, nunca con prefijo NEXT_PUBLIC
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (correos transaccionales de pedidos) ---
# Llave secreta de resend.com. Si falta, el sitio funciona igual pero no envía correos.
RESEND_API_KEY=
# Remitente. Sin dominio verificado usa el sandbox (solo entrega al correo de la cuenta Resend):
#   MultiAceros B&M <onboarding@resend.dev>
# Con dominio verificado: MultiAceros B&M <pedidos@multiacerosbym.com>
RESEND_FROM=
# Correo interno que recibe el aviso de cada pedido nuevo (por defecto, el de la empresa).
ORDER_NOTIFY_EMAIL=
