# ============ MultiAceros B&M — variables de entorno ============
# Copia este archivo a .env.local y completa los valores.
# NUNCA subas .env.local al repositorio (ya está en .gitignore).

# URL pública del sitio (para metadatos y SEO)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (se completa al crear el proyecto) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave de servicio: SOLO servidor, nunca con prefijo NEXT_PUBLIC
SUPABASE_SERVICE_ROLE_KEY=
